# Copy to .env and fill in. .env is gitignored.

# --- Anthropic (v0 default provider) ---
ANTHROPIC_API_KEY=

# --- Paths (host-side) ---
# Where the executor and sync services read/write. Defaults in compose.yml
# point into ./var/ inside the repo; override if you want state elsewhere.
VAULT_COPY_PATH=./var/vault-copy
PROPOSALS_PATH=./var/proposals

# The user's real Obsidian vault. The sync service reads/writes here.
VAULT_PATH=C:\Users\taylor\Documents\Taylor Notes

# --- Future providers (not used in v0) ---
# OPENROUTER_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434/v1

# --- Future: Google read-only (not used in v0) ---
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REFRESH_TOKEN=

# --- Future: Twilio (not used in v0) ---
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
# TWILIO_TO_NUMBER=
