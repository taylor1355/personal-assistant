# Copy to .env and fill in. .env is gitignored.

# === LLM providers ===

# Default cloud provider (v0+).
ANTHROPIC_API_KEY=

# Optional: cheaper / model-variety routing layer (v1+).
# OPENROUTER_API_KEY=

# Optional: local model server (v1+). Compose's host-loopback shorthand:
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1

# === Linear (issue tracking; v1+) ===

# Personal API key from Linear → Settings → API → Personal API keys.
LINEAR_API_KEY=
# Team key (the prefix in issue identifiers, e.g. PA in PA-42).
LINEAR_TEAM_KEY=PA

# === Paths ===

# In-container vault root (sync mounts the agent's vault copy here).
# Override only if you change compose.yml's volume mount.
VAULT_ROOT=/data/vault

# In-container proposals dir.
PROPOSALS_PATH=/data/proposals

# Host-side paths (read by sync, executor, dispatcher).
VAULT_COPY_PATH=./var/vault-copy
VAULT_PATH=C:\Users\taylor\Documents\Taylor Notes

# === User context ===

# IANA timezone, used to compute "today" for journal section extraction
# and scheduled triggers.
USER_TIMEZONE=America/New_York

# === Google read-only (v1+, not used in v0) ===
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REFRESH_TOKEN=

# === Twilio (SMS; v1+, not used in v0) ===
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
# TWILIO_TO_NUMBER=

# === GitHub (dev-work; v2+, not used in v0/v1) ===
# Personal Access Token (or GitHub App installation token) scoped to
# repos the agent is permitted to PR against.
# GITHUB_TOKEN=
# Comma-separated list of allowed repos for agent PRs (e.g.
# taylor1355/personal-assistant,taylor1355/npc).
# GITHUB_ALLOWED_REPOS=
