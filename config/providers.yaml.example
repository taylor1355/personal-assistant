# Copy to config/providers.yaml and adjust. Provider routing config.
#
# v0 uses `cloud-strong` for everything. Later versions will add local
# models via Ollama and OpenRouter for breadth.

# Which provider is used for each agent role. Any role not listed falls
# back to `default`.
routing:
  default: cloud-strong
  # overrides:
  #   research_agent: cloud-strong
  #   vault_organizer: local-strong
  #   root: cloud-fast

providers:
  cloud-strong:
    kind: anthropic           # native SDK — enables prompt caching, thinking
    model: claude-opus-4-7
    # api_key comes from ANTHROPIC_API_KEY

  # --- Not yet used ---
  # cloud-fast:
  #   kind: openai_compat
  #   base_url: https://openrouter.ai/api/v1
  #   model: anthropic/claude-haiku-4-5
  #   api_key_env: OPENROUTER_API_KEY
