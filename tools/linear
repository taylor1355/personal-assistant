#!/usr/bin/env bash
# Linear CLI for personal-assistant.
# Usage: tools/linear <command> [args]
# Commands: status | todo | project <name> | issue <id> | pickup <id> [id...] |
#           done <id> [id...] | set-state <State> <id> [id...] | set-priority <p> <id> [id...] |
#           search <query> | blocked | next | create | update | comment <id> <body> |
#           link <blocker-id> <blocked-id> | unlink <blocker-id> <blocked-id> | whoami

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
LINEAR_DIR="$SCRIPT_DIR/linear-pm"

# Load API key + team key from .env if present (env var takes precedence).
if [[ -f "$PROJECT_ROOT/.env" ]]; then
  if [[ -z "${LINEAR_API_KEY:-}" ]]; then
    LINEAR_API_KEY=$(grep -E '^LINEAR_API_KEY=' "$PROJECT_ROOT/.env" 2>/dev/null | head -1 | cut -d= -f2- | tr -d '"' || true)
  fi
  if [[ -z "${LINEAR_TEAM_KEY:-}" ]]; then
    LINEAR_TEAM_KEY=$(grep -E '^LINEAR_TEAM_KEY=' "$PROJECT_ROOT/.env" 2>/dev/null | head -1 | cut -d= -f2- | tr -d '"' || true)
  fi
fi

if [[ -z "${LINEAR_API_KEY:-}" ]]; then
  echo "Error: LINEAR_API_KEY not found. Add it to .env:" >&2
  echo "  LINEAR_API_KEY=lin_api_..." >&2
  exit 1
fi

# Default team key when not configured. The agent's Linear team is "PA".
LINEAR_TEAM_KEY="${LINEAR_TEAM_KEY:-PA}"

export LINEAR_API_KEY
export LINEAR_TEAM_KEY
exec npx --prefix "$LINEAR_DIR" tsx "$LINEAR_DIR/src/linear-cli.ts" "$@"
